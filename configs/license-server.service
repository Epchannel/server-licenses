[Unit]
Description=License Server API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/license-server
Environment="PATH=/root/license-server/venv/bin"
ExecStart=/root/license-server/venv/bin/python /root/license-server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
