# EP Channel License Server - Environment Variables
# Copy this file to .env and change the values before deploying

# HMAC Signing Key (used for license signature verification)
SECRET_KEY=change-this-to-a-random-string-64-chars

# JWT Secret Key (used for admin/user token signing)
JWT_SECRET_KEY=change-this-to-another-random-string-64-chars

# Panel Access Key (used for admin panel login)
PANEL_ACCESS_KEY=change-this-to-a-strong-key

# API Key (optional, for external API access)
API_KEY_1=change-this-to-a-random-api-key

# Database URL (default: SQLite, change to PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost/license_server
DATABASE_URL=sqlite:///./license_server.db
